# KAIROS Backend Environment Variables
# Copy this file to .env and fill in your credentials

# ─── Flask ───────────────────────────────────────────────────
SECRET_KEY=kairos-super-secret-key-change-this-in-production
FLASK_DEBUG=true
PORT=5000

# ─── OpenWeatherMap ──────────────────────────────────────────
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ─── Sentinel Hub ────────────────────────────────────────────
# Register at: https://www.sentinel-hub.com/
# Create OAuth client → copy credentials below
SENTINEL_HUB_CLIENT_ID=sh-79bddf1d-fc74-4bda-a959-9de6eefa423f
SENTINEL_HUB_CLIENT_SECRET=4nWvUTmpk91cAYjscfCGEaa0mdzCyfjh
SENTINEL_CLIENT_ID=sh-79bddf1d-fc74-4bda-a959-9de6eefa423f
SENTINEL_CLIENT_SECRET=4nWvUTmpk91cAYjscfCGEaa0mdzCyfjh

# ─── Database ────────────────────────────────────────────────
DATABASE_PATH=kairos.db

# ─── File Upload ─────────────────────────────────────────────
UPLOAD_FOLDER=uploads

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── AI Model ────────────────────────────────────────────────
MODEL_PATH=models/best_model.keras
